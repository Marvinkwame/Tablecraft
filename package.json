{
  "name": "tablecraft",
  "version": "0.1.0",
  "description": "Batteries-included TanStack Table wrapper for React — TypeScript-first, headless, zero UI lock-in",
  "keywords": [
    "react",
    "table",
    "tanstack",
    "typescript",
    "headless",
    "datagrid",
    "tanstack-table"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "peerDependencies": {
    "@tanstack/react-table": ">=8",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "match-sorter": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tanstack/react-table": "^8.17.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^14.3.0",
    "jsdom": "^24.0.0",
    "match-sorter": "^6.3.4",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "license": "MIT"
}
