{
  "name": "@marvinackerman/tablecraft",
  "version": "2.6.0",
  "description": "Batteries-included TanStack Table wrapper for React — TypeScript-first, headless, zero UI lock-in",
  "keywords": [
    "react",
    "table",
    "tanstack",
    "typescript",
    "headless",
    "datagrid",
    "tanstack-table"
  ],
  "main": "./dist/src/index.js",
  "module": "./dist/src/index.mjs",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.mjs",
      "require": "./dist/src/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.mjs",
      "require": "./dist/testing/index.js"
    },
    "./devtools": {
      "types": "./dist/devtools/index.d.ts",
      "import": "./dist/devtools/index.mjs",
      "require": "./dist/devtools/index.js"
    },
    "./zod": {
      "types": "./dist/zod/index.d.ts",
      "import": "./dist/zod/index.mjs",
      "require": "./dist/zod/index.js"
    }
  },
  "files": [
    "dist",
    "testing",
    "devtools",
    "zod",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "peerDependencies": {
    "@tanstack/react-table": ">=8",
    "react": ">=18",
    "@tanstack/react-virtual": ">=3",
    "zod": ">=3.23.0"
  },
  "peerDependenciesMeta": {
    "match-sorter": {
      "optional": true
    },
    "@tanstack/react-query": {
      "optional": true
    },
    "@testing-library/react": {
      "optional": true
    },
    "@tanstack/react-virtual": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.96.1",
    "@tanstack/react-table": "^8.17.0",
    "@tanstack/react-virtual": "^3.13.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^14.3.0",
    "jsdom": "^24.0.0",
    "match-sorter": "^6.3.4",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0",
    "zod": "^4.4.3",
    "zod-v3": "npm:zod@^3.25.76"
  },
  "scripts": {
    "build": "tsup && node scripts/check-dts.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Marvinkwame/Tablecraft.git"
  },
  "homepage": "https://github.com/Marvinkwame/Tablecraft#readme",
  "bugs": {
    "url": "https://github.com/Marvinkwame/Tablecraft/issues"
  },
  "license": "MIT"
}
